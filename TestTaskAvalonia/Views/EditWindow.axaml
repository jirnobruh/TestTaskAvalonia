<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TestTaskAvalonia.Views.EditWindow"
        Title="Редактирование" Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" CanResize="False">
    <StackPanel Margin="20" Spacing="15">
        <TextBlock Name="Header" FontSize="18" FontWeight="Bold" />
        
        <StackPanel Name="FieldsContainer" Spacing="10">
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
            <Button Content="Сохранить" Click="OnSaveClick" Classes="accent" />
            <Button Content="Отмена" Click="OnCancelClick" />
        </StackPanel>
    </StackPanel>
</Window>