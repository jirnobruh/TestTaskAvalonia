<Window xmlns="https://github.com/avaloniaui"
        xmlns:dgrid="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:TestTaskAvalonia.Views"
        xmlns:vm="clr-namespace:TestTaskAvalonia.ViewModels"
        mc:Ignorable="d"
        x:Class="TestTaskAvalonia.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="TestTaskAvalonia">

    <DockPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    Margin="10">
            <Button Content="Создать тестовые данные"
                    Command="{Binding GenerateTestDataCommand}" />
            <Button Content="Очистить все справочники"
                    Command="{Binding ClearDataCommand}"
                    Margin="10"
                    Background="Red" Foreground="White"/>
        </StackPanel>

        <TabControl Margin="10">
            <TabItem Header="Организации">
                <views:OrganizationsView DataContext="{Binding OrganizationsVM}" />
            </TabItem>

            <TabItem Header="Сотрудники">
                <views:EmployeesView DataContext="{Binding EmployeesVM}" />
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>